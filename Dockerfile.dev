# syntax=docker/dockerfile:1.7
#
# Dev image — used by Makefile DEV_RUN for lint / test / format / generate.
# Host stays clean; heavy ML deps live only in CPU + CUDA prod images.
#
# Includes:
#   - python 3.12 + uv + ruff + pyright + pytest + coverage
#   - datamodel-code-generator (server-side Pydantic gen)
#   - openapi-python-client (Python client gen)
#   - Go 1.25 + oapi-codegen (Go client gen)

FROM python:3.12-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    GOTOOLCHAIN=local \
    PATH=/usr/local/go/bin:/root/go/bin:${PATH}

RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        git \
        curl \
        make \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Go toolchain (oapi-codegen) — pinned by SHA.
RUN curl -fsSL https://go.dev/dl/go1.25.0.linux-amd64.tar.gz \
        | tar -C /usr/local -xz \
    && go install github.com/oapi-codegen/oapi-codegen/v2/cmd/oapi-codegen@v2.4.1 \
    && mv /root/go/bin/oapi-codegen /usr/local/bin/oapi-codegen

# Python tooling — runtime deps (so generated handlers load), generators,
# linters, test harness.
COPY --from=ghcr.io/astral-sh/uv:0.11.15 /uv /usr/local/bin/uv
RUN pip install --no-cache-dir \
        fastapi==0.115.12 \
        uvicorn==0.34.2 \
        pydantic==2.11.4 \
        python-multipart==0.0.20 \
        ruff==0.7.0 \
        pyright==1.1.385 \
        pytest==8.3.3 \
        pytest-asyncio==0.24.0 \
        pytest-cov==5.0.0 \
    && pip install --no-cache-dir \
        'datamodel-code-generator[http]' \
        openapi-python-client

WORKDIR /work
