# Secrets — never commit
.env
.env.*
*.env
!.env.example
.envrc
.direnv/
.git-credentials
secrets/
credentials.json
*.pem
*.key
*.p12
*.pfx

# Dev-level markdown — never commit
CLAUDE.md
implplan.md
ANUSTIMES*.md
.brutal-review.md
.brutal-review-*.md
*.scratch.md
NOTES.md
PLAN.md
TODO.md
WIP.md

