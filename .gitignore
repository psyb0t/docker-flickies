git-update.sh
.claude/
about.txt
pyrightconfig.json
mypy.ini
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.ipynb_checkpoints/
__pycache__/
*.pyc
*.pyo
*.egg-info/
build/
dist/

# Local venvs + tool-managed Python versions
.venv/
venv/
.python-version
.tool-versions

# Editor / IDE / OS clutter
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Backup / scratch
*.bak
*.orig
*.rej
*.log

# Local compose / Makefile overrides
Makefile.local
compose.override.yaml
compose.override.yml
docker-compose.override.yaml
docker-compose.override.yml
docker-compose.dev.yaml
docker-compose.dev.yml

# Model snapshots & ML weights — never commit. The e2e cache stores
# multi-GB UVR/torch checkpoints; without these globs a wayward
# `git add` could drag the whole cache into history.
/models/
/data/
*.safetensors
*.bin
*.ckpt
*.pt
*.pth
*.onnx
*.h5
*.tflite
*.pb
*.mlmodel
*.gguf
*.npz

# Archives — usually accidental: a tarball downloaded for inspection,
# a model bundle, etc. Never want these committed.
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.tgz
*.zip
*.7z
*.rar

# HF / torch caches if a runaway run drops them at top level.
.hf_cache/
hf_cache/
huggingface/
.torch/
torch_cache/

# Node — shouldn't appear in this repo, defensive.
node_modules/

# Research dirs
.research_files/

# Integration test cache
.e2e-cache/

# Test fixtures auto-generated by the harness on every run (synthetic
# sine-tone via ffmpeg lavfi). Never committed.
tests/integration/.fixtures/*
!tests/integration/.fixtures/.gitkeep
.telemetry/
